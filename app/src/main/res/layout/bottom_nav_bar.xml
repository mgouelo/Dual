<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/rounded_navbar_background"
    android:elevation="8dp"
    android:paddingStart="40dp"
    android:paddingEnd="40dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <!-- Bouton "Home" - L'ensemble du LinearLayout est cliquable -->
    <LinearLayout
        android:id="@+id/nav_home_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground"
        android:padding="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/home_blue"
            android:background="@android:color/transparent"
            android:clickable="false"
            android:focusable="false"
            android:duplicateParentState="true"
            app:tint="@color/bottom_nav_color"
            android:contentDescription="@string/home"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/home"
            android:textColor="@color/bottom_nav_color"
            android:duplicateParentState="true"
            android:textSize="18sp"/>
    </LinearLayout>

    <!-- Bouton "Classes" - L'ensemble du LinearLayout est cliquable -->
    <LinearLayout
        android:id="@+id/nav_classes_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground"
        android:padding="8dp"
        app:layout_constraintStart_toEndOf="@id/nav_home_button"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="48dp">

        <ImageButton
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/person"
            android:background="@android:color/transparent"
            android:clickable="false"
            android:focusable="false"
            android:duplicateParentState="true"
            app:tint="@color/bottom_nav_color"
            android:contentDescription="@string/classes"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/classes"
            android:textColor="@color/bottom_nav_color"
            android:duplicateParentState="true"
            android:textSize="18sp"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
